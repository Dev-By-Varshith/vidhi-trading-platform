## 4. The Bot Strategy Library (Inline C++ on Core 2)

All 5 bots compiled C++, inline in Game Master. No IPC. No fork. ~10ns total.

```cpp
// bot_fleet.hpp

// Bot 1: Market Maker
// Posts bid/ask around best. Widens spread when inventory builds.
// Contestant who takes liquidity pays spread every time.
struct MarketMaker {
    int64_t inventory = 0;
    double  quote_offset = 0.01;

    void compute(const LOBSnapshot& snap, const PriceSignal& sig,
                 OrderBuffer& out) {
        double skew = inventory * 0.001;  // Avellaneda-Stoikov skew
        cancel_stale_quotes(out);
        out.limit_buy(snap.mid - quote_offset - skew, 50);
        out.limit_sell(snap.mid + quote_offset - skew, 50);
    }
    void on_fill(Fill f) { inventory += (f.side == BUY ? 1 : -1) * f.volume; }
};

// Bot 2: Momentum Trader
// If price rises above EMA → buys. Contestant causing spike gets front-run.
struct MomentumTrader {
    double ema = 0.0;
    void compute(const LOBSnapshot& snap, const PriceSignal& sig,
                 OrderBuffer& out) {
        ema = 0.95 * ema + 0.05 * snap.mid;
        double signal = snap.mid - ema;
        if (signal > 2 * sig.tick_size)  out.market_buy(30);
        if (signal < -2 * sig.tick_size) out.market_sell(30);
    }
};

// Bot 3: Mean Reversion
// Fades moves that diverge from underlying signal.
// Contestant can't spam aggressive orders — this bot sells into it.
struct MeanReversionBot {
    void compute(const LOBSnapshot& snap, const PriceSignal& sig,
                 OrderBuffer& out) {
        double dev = snap.mid - sig.fair_value;
        if (dev >  5 * sig.tick_size) out.limit_sell(snap.mid - sig.tick_size, 100);
        if (dev < -5 * sig.tick_size) out.limit_buy(snap.mid  + sig.tick_size, 100);
    }
};

// Bot 4: Noise Trader
// Random realistic order flow. Makes LOB feel alive.
struct NoiseTrader {
    uint64_t rng = 0xDEADBEEFCAFEBABE;
    void compute(const LOBSnapshot& snap, const PriceSignal& sig,
                 OrderBuffer& out) {
        uint64_t r = xorshift64(rng);
        if (r % 3 != 0) return;
        double offset = (int(r % 5) - 2) * sig.tick_size;
        (r % 2) ? out.limit_buy(snap.bid + offset, 10 + r % 40)
                : out.limit_sell(snap.ask + offset, 10 + r % 40);
    }
};

// Bot 5: Sniper / Arbitrageur
// Keeps LOB anchored to fair value. No free money from stale quotes.
struct SniperBot {
    void compute(const LOBSnapshot& snap, const PriceSignal& sig,
                 OrderBuffer& out) {
        if (snap.best_ask < sig.fair_value - sig.tick_size)
            out.market_buy(snap.best_ask_volume);
        if (snap.best_bid > sig.fair_value + sig.tick_size)
            out.market_sell(snap.best_bid_volume);
    }
};
```

