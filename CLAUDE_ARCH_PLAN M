## 3. The Shared Rendezvous Struct (Extended for Dynamic Bots)

The rendezvous now carries LOB depth + fills in both directions:

```cpp
// rendezvous.hpp — v5.0 layout
// All fields on dedicated 64-byte cache lines (no false sharing)

struct alignas(64) SharedMem {

    // ─── Cache Line 0: GM signal ───────────────────────────────────────
    std::atomic<uint64_t> gm_sequence{0};
    uint8_t _pad0[56];

    // ─── Cache Lines 1-4: Market State (GM writes, Contestant reads) ───
    struct MarketState {
        double  bid_price;            // best bid
        double  ask_price;            // best ask
        double  mid_price;
        double  spread;               // widens when market maker scared
        double  last_trade_price;
        int64_t last_trade_volume;
        int64_t bid_depth[5];         // [best, -1, -2, -3, -4 ticks]
        int64_t ask_depth[5];         // [best, +1, +2, +3, +4 ticks]
        uint64_t timestamp;
        double  underlying_signal;    // reference fair value
        uint8_t _pad[16];
    } market;  // 128 bytes = 2 cache lines

    // ─── Cache Line 6-7: Fill Notifications + Contestant Status ────────
    struct FillNotification {
        int64_t  order_id;
        double   fill_price;
        int64_t  fill_volume;
        uint8_t  side;          // 0=buy_filled, 1=sell_filled
        uint8_t  pad[7];
    };
    FillNotification fills[4];    // up to 4 fills per tick
    int32_t  fill_count;
    int64_t  position;            // contestant's net position
    double   cash;                // contestant's cash
    double   pnl;                 // mark-to-market PnL
    int32_t  open_order_count;
    uint8_t  _pad1[8];            // 128 bytes = 2 cache lines

    // ─── Cache Line 8: Sandbox signal ──────────────────────────────────
    std::atomic<uint64_t> sb_sequence{0};
    uint8_t _pad2[56];

    // ─── Cache Lines 9-12: Order Zone (Contestant writes) ──────────────
    struct Order {
        uint8_t  type;    // 0=HOLD, 1=LIMIT_BUY, 2=LIMIT_SELL,
                          // 3=MARKET_BUY, 4=MARKET_SELL, 5=CANCEL
        uint8_t  pad[7];
        double   price;   // for limit orders
        int64_t  volume;
        int64_t  order_id; // for cancels
    };
    Order   orders[4];    // up to 4 orders per tick
    int32_t order_count;
    uint8_t _pad3[28];   // 192 bytes = 3 cache lines

    // ─── Cache Lines 15-16: Persistent State Zone ──────────────────────
    int64_t contestant_state[16];  // contestant persists own state here
};                                  // 0ns serialization, GM passes back unchanged
// Total: 1024 bytes, zero false sharing
