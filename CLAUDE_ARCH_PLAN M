## 5. The Persistent LOB

```cpp
// persistent_lob.hpp
struct alignas(64) PersistentLOB {

    // HOT: single cache line (99% of matches happen here)
    double   best_bid_price;
    int64_t  best_bid_volume;
    uint64_t best_bid_order_id;
    double   best_ask_price;
    int64_t  best_ask_volume;
    uint64_t best_ask_order_id;
    double   last_trade_price;
    uint8_t  _pad[8];  // 64 bytes

    // FULL DEPTH: resting orders (24KB → L1 resident)
    alignas(64) int64_t  bid_volumes[MAX_LEVELS];
    alignas(64) int64_t  ask_volumes[MAX_LEVELS];
    alignas(64) uint64_t bid_fifo_heads[MAX_LEVELS]; // FIFO order tracking

    // ORDER REGISTRY: maps order_id → {price, volume, side, participant}
    std::unordered_map<uint64_t, OrderRecord> order_registry;

    // Match ALL orders (bots arrive before contestant — same core lead)
    std::vector<Fill> process_all(std::vector<Order>& orders) {
        // Stable sort by arrival_tsc — bots always arrive first
        std::stable_sort(orders.begin(), orders.end(),
            [](auto& a, auto& b){ return a.arrival_tsc < b.arrival_tsc; });

        std::vector<Fill> fills;
        for (auto& o : orders) {
            auto f = match(o);
            fills.insert(fills.end(), f.begin(), f.end());
        }
        update_best_ptrs();
        return fills;
    }
};
```

